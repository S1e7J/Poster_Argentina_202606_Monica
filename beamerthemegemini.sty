           \colorbox{orange!80!brown}{%
             \parbox[c][1.8em][c]{0.33\columnwidth}{%
               \centering
               \fontsize{10}{10}\selectfont
               \textbf{ASRS --- volcanic, nuclear \& impact scenarios}
             }%
           }%
          }
        \end{column}
        % =====================================================
        % RIGHT COLUMN (META)
        % =====================================================
        \begin{column}{0.24\linewidth}
          \raggedleft
\begin{tcolorbox}[
    colback=gray!20,        % fondo gris claro (20% gris)
    colframe=gray!40,       % borde un poco más oscuro (opcional)
    boxrule=0.5pt,          % grosor del borde (mantenido fino)
    arc=3mm,                % esquinas redondeadas (más grande)
    left=3mm,               % padding horizontal
    right=3mm,
    top=2.5mm,              % padding vertical
    bottom=2.5mm,
    % Si prefieres un fondo translúcido real, sustituye las líneas anteriores por:
    % colback=gray, opacityback=0.25, colframe=gray, opacityframe=0.3,
    % Pero ten en cuenta que la transparencia depende del visor de PDF.
  ]
  \centering
  \fontsize{13}{15}\selectfont
  \textbf{Volcanic Impacts on Climate}\\
  \textbf{and Society 2026}
\end{tcolorbox}
          \vspace{0.4em}
          {\fontsize{20}{22}\selectfont
           Published in REDER, 8(2), 2024\par}
          \vspace{0.2em}
          {\fontsize{20}{22}\selectfont
           DOI: 10.55467/reder.v8i2.164\par}
        \end{column}
      \end{columns}
    \end{minipage}

    \vspace*{1.2em}                         % espacio inferior (también funciona por vmode)
  \end{beamercolorbox}
}
